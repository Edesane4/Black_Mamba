# Black_Mamba environment template. Copy to .env and fill in.
# §B.20 — Credentials Checklist

# --- Kalshi ---
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
KALSHI_MODE=paper

# --- Weather data sources ---
NWS_USER_AGENT=BlackMamba/1.0 (contact@example.com)
SYNOPTIC_API_TOKEN=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=

# --- Obsidian ---
OBSIDIAN_VAULT_PATH=

# --- Storage / runtime ---
DATABASE_URL=sqlite:///./data/black_mamba.db
LOG_LEVEL=INFO

# --- Mode (must match KALSHI_MODE) ---
BLACK_MAMBA_MODE=paper
BLACK_MAMBA_STARTING_BALANCE=1000

# --- Risk parameters (defaults from §B.4.3 / §B.7) ---
DAILY_LOSS_CIRCUIT_BREAKER_PCT=12
MAX_TOTAL_EXPOSURE_PCT=40
MIN_TRADE_DOLLARS=25
